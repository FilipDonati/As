{
  "@@locale": "en",
  "appTitle": "Multilingual App",
  "@appTitle": {
    "description": "The application title"
  },
  "welcome": "Welcome!",
  "@welcome": {
    "description": "Welcome message"
  },
  "hello": "Hello {name}!",
  "@hello": {
    "description": "Greeting with name parameter",
    "placeholders": {
      "name": {
        "type": "String",
        "example": "John"
      }
    }
  },
  "itemCount": "{count, plural, =0{No items} =1{1 item} other{{count} items}}",
  "@itemCount": {
    "description": "Number of items with plural support",
    "placeholders": {
      "count": {
        "type": "int",
        "example": "5"
      }
    }
  },
  "selectLanguage": "Select Language",
  "changeLanguage": "Change Language",
  "currentLanguage": "Current Language: {language}",
  "@currentLanguage": {
    "placeholders": {
      "language": {
        "type": "String"
      }
    }
  },
  "translate": "Translate",
  "autoTranslate": "Auto Translate",
  "enterText": "Enter text to translate"
}